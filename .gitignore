# nix build symlink
result

# raw voice examples used to derive VOICE.md; kept for future re-distillation, never committed (may contain private message content)
home/.voice-examples/

# herdr runtime artifacts (regenerated at runtime; never commit)
home/.config/herdr/*.log
home/.config/herdr/release-notes.json
home/.config/herdr/session.json
home/.config/herdr/*.sock

# herdr plugin machine-specific artifacts (regenerated by `herdr plugin install`).
# plugins.json embeds absolute paths + a per-install hash; plugins/github/ is the
# cloned source + built binary. Both are per-machine; only plugins/config/ is committed.
home/.config/herdr/plugins.json
home/.config/herdr/plugins/github/

# herdr-plus templates: generated from herdr-plus.nix on every activation and
# regenerated by ./rebuild.sh, so they're derived artifacts, not source. Scoped to
# the two generated dirs only, leaving the plugin's own config trackable if needed.
home/.config/herdr/plugins/config/cloudmanic.herdr-plus/projects/
home/.config/herdr/plugins/config/cloudmanic.herdr-plus/worktrees/

# personal WIP / scratch plans — local notes, never committed to the public dotfiles
.plans/
